// SCHEMA_VERSION: family-user-device-state-v1
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PARENT
  CHILD
}

model Family {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  invites        Invite[]
  aacMessages    AacMessage[]
  libraryItems   FamilyLibraryItem[]
  librarySets    FamilyLibrarySet[]
  childHomeNodes ChildHomeNode[]
}

model User {
  id           String             @id @default(cuid())
  familyId     String
  role         UserRole
  name         String?
  avatarItemId String?
  avatarItem   FamilyLibraryItem? @relation("UserAvatarItem", fields: [avatarItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family         Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  devices        Device[]
  invitesCreated Invite[] @relation("InvitesCreatedByUser")

  sentMessages     AacMessage[] @relation("AacMessageFromUser")
  receivedMessages AacMessage[] @relation("AacMessageToUser")

  sentReplies         AacReply[]            @relation("AacReplyFromUser")
  receivedReplies     AacReply[]            @relation("AacReplyToUser")
  createdLibraryItems FamilyLibraryItem[]
  createdLibrarySets  FamilyLibrarySet[]
  childHomeTargets    ChildHomeNodeTarget[]

  @@index([familyId])
  @@index([familyId, role])
}

model Device {
  id String @id @default(cuid())

  /// Stable identifier generated on the device (UUID recommended).
  /// Used as external identifier in APIs and as the join key for telemetry/commands.
  deviceId String @unique

  userId    String
  name      String?
  tokenHash String

  fcmToken          String?
  fcmTokenUpdatedAt DateTime?
  lastPushAt        DateTime?

  platform   String? // "android"
  model      String? // e.g. Build.MODEL
  osVersion  String? // e.g. "14"
  appVersion String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  telemetry Telemetry[]
  commands  Command[]

  state    DeviceState?
  settings DeviceSetting[]

  @@index([userId])
  @@index([userId, createdAt])
}

model DeviceState {
  /// 1:1 with Device by deviceId (external id)
  deviceId String @id

  batteryPercent Int?
  volumePercent  Int?
  isCharging     Boolean?

  /// timestamp from device (optional)
  reportedAt DateTime?

  /// server-side update time
  updatedAt DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
}

model DeviceSetting {
  id        String   @id @default(cuid())
  deviceId  String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@unique([deviceId, key])
  @@index([deviceId])
}

model Invite {
  id              String @id @default(cuid())
  familyId        String
  createdByUserId String

  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  role UserRole

  createdAt DateTime @default(now())

  family        Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdByUser User   @relation("InvitesCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([familyId, expiresAt])
  @@index([createdByUserId])
}

model Telemetry {
  id        String   @id @default(cuid())
  deviceId  String
  type      String
  payload   Json
  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@index([type, createdAt])
}

model Command {
  id          String    @id @default(cuid())
  deviceId    String
  type        String
  payload     Json
  status      String    @default("queued")
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  ackedAt     DateTime?

  device Device @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@index([status, createdAt])
}

model AacMessage {
  id String @id @default(cuid())

  familyId   String
  fromUserId String
  toUserId   String

  // Основное сообщение (карточки / фото / что угодно)
  message Json

  // Возможные ответы
  suggestedReplies Json

  createdAt  DateTime  @default(now())
  answeredAt DateTime?

  // связи
  family   Family @relation(fields: [familyId], references: [id])
  fromUser User   @relation("AacMessageFromUser", fields: [fromUserId], references: [id])
  toUser   User   @relation("AacMessageToUser", fields: [toUserId], references: [id])

  reply AacReply?

  @@index([familyId])
  @@index([toUserId])
  @@index([fromUserId])
}

model AacReply {
  id         String   @id @default(cuid())
  messageId  String   @unique
  fromUserId String
  toUserId   String
  reply      Json
  createdAt  DateTime @default(now())

  // связи
  message  AacMessage @relation(fields: [messageId], references: [id])
  fromUser User       @relation("AacReplyFromUser", fields: [fromUserId], references: [id])
  toUser   User       @relation("AacReplyToUser", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
}

model FamilyLibraryItem {
  id              String @id @default(cuid())
  familyId        String
  createdByUserId String

  label     String
  source    LibraryItemSource
  sourceRef String?

  storageKey String? @unique

  mimeType      String?
  width         Int?
  height        Int?
  fileSizeBytes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family         Family @relation(fields: [familyId], references: [id])
  createdByUser  User   @relation(fields: [createdByUserId], references: [id])
  avatarForUsers User[] @relation("UserAvatarItem")

  setItems       FamilyLibrarySetItem[]
  coverForSets   FamilyLibrarySet[]     @relation("LibrarySetCoverItem")
  childHomeNodes ChildHomeNode[]

  @@index([familyId, createdAt])
  @@index([familyId, source, createdAt])
  @@index([createdByUserId, createdAt])
}

model FamilyLibrarySet {
  id              String @id @default(cuid())
  familyId        String
  createdByUserId String

  name        String
  coverItemId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family        Family             @relation(fields: [familyId], references: [id])
  createdByUser User               @relation(fields: [createdByUserId], references: [id])
  coverItem     FamilyLibraryItem? @relation("LibrarySetCoverItem", fields: [coverItemId], references: [id])

  items FamilyLibrarySetItem[]

  @@index([familyId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([coverItemId])
}

model FamilyLibrarySetItem {
  id        String @id @default(cuid())
  setId     String
  itemId    String
  sortOrder Int    @default(0)

  set  FamilyLibrarySet  @relation(fields: [setId], references: [id], onDelete: Cascade)
  item FamilyLibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([setId, itemId])
  @@index([setId, sortOrder])
  @@index([itemId])
}

enum LibraryItemSource {
  FAMILY_PHOTO
  ARASAAC
}

model ChildHomeNode {
  id        String  @id @default(cuid())
  familyId  String
  itemId    String
  parentId  String?
  type      String // MENU | ACTION
  sortOrder Int     @default(0)

  targetMode String @default("ALL_PARENTS") // ALL_PARENTS | SELECTED_USERS | NONE

  blinkEnabled Boolean @default(true)
  blinkSeconds Int     @default(60)

  family   Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  item     FamilyLibraryItem     @relation(fields: [itemId], references: [id])
  parent   ChildHomeNode?        @relation("ChildHomeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ChildHomeNode[]       @relation("ChildHomeTree")
  targets  ChildHomeNodeTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChildHomeNodeTarget {
  id     String @id @default(cuid())
  nodeId String
  userId String

  node ChildHomeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}
